# Groq API Keys (supports multiple keys for fallback on rate limits)
GROQ_API_KEY_1=your_first_groq_api_key_here
GROQ_API_KEY_2=your_second_groq_api_key_here
# Fallback to single key if only one is available
GROQ_API_KEY=your_groq_api_key_here
PORT=3000
CACHE_TTL_MINUTES=20
CRON_SCHEDULE=*/15 * * * *

# CORS Configuration
# Comma-separated list of allowed origins for production
# Example: ALLOWED_ORIGINS=https://my-app.vercel.app,https://mydomain.com
ALLOWED_ORIGINS=https://my-app.vercel.app,https://mydomain.com

# Paper Trading Configuration
RISK_PER_TRADE_PERCENT=1
MIN_CONFIDENCE_THRESHOLD=80
MIN_RR_RATIO=2
PRICE_UPDATE_INTERVAL=30
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_HOURS=4

# Symbol Configuration (BTC-only trading - Updated 17/04/2026)
ENABLED_SYMBOLS=BTC
MAX_POSITIONS_PER_SYMBOL=8

# Prediction Reversal Check
PREDICTION_REVERSAL_ENABLED=true
PREDICTION_REVERSAL_CONFIDENCE=80

# Session Timing (ICT: focus on high-liquidity sessions)
ALLOWED_SESSIONS=london,ny_killzone
# London: 07:00-10:00 UTC
# NY Killzone: 12:00-15:00 UTC

# Partial Take Profits (ICT: take profits in stages)
PARTIAL_TP_ENABLED=true
PARTIAL_TP_RATIOS=0.5,0.5
PARTIAL_TP_RR_LEVELS=1.0,2.0

# Trailing Stop (ICT: move SL to breakeven after TP1)
TRAILING_STOP_ENABLED=true
TRAIL_AFTER_RR=1.0
TRAIL_DISTANCE_PCT=0.5

# Price Updates
PRICE_UPDATE_INTERVAL_MS=30000

# API Rate Limiting
# CoinGecko free tier: ~10-50 calls/minute
# Binance public API: 1200 calls/minute
# Paper trading uses Binance real-time API (no rate limit issues)
COINGECKO_MIN_DELAY_MS=2000

# Binance Futures Configuration (REST API)
# Supports both Demo Trading and Mainnet
# Switch between them by changing BINANCE_BASE_URL

# Enable/disable Binance Futures integration
# Set to 'true' to enable trading
# Default: false (disabled)
BINANCE_ENABLED=false

# Binance API Base URL
# Demo Trading: https://demo-fapi.binance.com
# Mainnet: https://fapi.binance.com
# Default: demo-fapi.binance.com (Demo Trading)
BINANCE_BASE_URL=https://demo-fapi.binance.com

# Binance API Key
# Get your API key from: https://www.binance.com/en/my/settings/api-management
# For Demo Trading: https://testnet.binancefuture.com/
# Go to API Management → Create API
# Required only if BINANCE_ENABLED=true
BINANCE_API_KEY=your_binance_api_key

# Binance API Secret Key
# Get your Secret Key from the same place as API Key
# Required only if BINANCE_ENABLED=true
# Keep this secret and never commit to version control
BINANCE_API_SECRET=your_binance_secret_key

# Trading symbol
# Currently supports: BTCUSDT only
# Future enhancement: Multi-symbol support (ETHUSDT, SOLUSDT, etc.)
BINANCE_SYMBOL=BTCUSDT

# Leverage multiplier for trading
# Range: 1-125 (Binance Futures limits)
# Recommended: 1-3 for risk management
# Higher leverage = higher risk and potential returns
# Default: 20
BINANCE_LEVERAGE=20

# Request window for signed requests (milliseconds)
# Binance uses this to prevent replay attacks
# Default: 5000 (5 seconds)
BINANCE_RECV_WINDOW=5000
