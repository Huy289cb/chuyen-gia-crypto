# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_1=your_first_groq_api_key_here
GROQ_API_KEY_2=your_second_groq_api_key_here

# Binance API Configuration
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET_API_KEY=your_binance_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_binance_testnet_api_secret_here
BINANCE_ENABLED=false
BINANCE_BASE_URL=https://demo-fapi.binance.com
BINANCE_SYMBOL=BTCUSDT
BINANCE_LEVERAGE=20
BINANCE_RECV_WINDOW=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=crypto_user
DB_PASSWORD=crypto_password
DB_NAME=crypto_analyzer
DB_SSLMODE=disable

# Server Configuration
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
GIN_MODE=debug

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Analysis Configuration
ICT_CONFIDENCE_THRESHOLD=0.70
KIM_NGHIA_CONFIDENCE_THRESHOLD=0.75
AUTO_ENTRY_CONFIDENCE_THRESHOLD=0.80

# Trading Configuration
RISK_PERCENT=0.01
MIN_RR_RATIO=2.0
MIN_SL_DISTANCE=0.0075
COOLDOWN_HOURS=4
RISK_PER_TRADE_PERCENT=1
MIN_CONFIDENCE_THRESHOLD=80
MAX_CONSECUTIVE_LOSSES=3

# Scheduler Configuration
ENABLE_KIM_NGHIA_SCHEDULER=true
ENABLE_ICT_SCHEDULER=false
ENABLE_PRICE_UPDATE_SCHEDULER=true

# Timezone Configuration
TIMEZONE=UTC
DISPLAY_TIMEZONE=Asia/Ho_Chi_Minh

# Paper Trading Configuration
PAPER_TRADING_ENABLED=true
STARTING_BALANCE=100

# Testnet Configuration
TESTNET_ENABLED=false
TESTNET_URL=https://testnet.binance.vision

# Cache Configuration
CACHE_ENABLED=false
CACHE_TTL=300

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# CORS Configuration
ALLOWED_ORIGINS=https://my-app.vercel.app,https://mydomain.com

# Symbol Configuration (BTC-only trading)
ENABLED_SYMBOLS=BTC
MAX_POSITIONS_PER_SYMBOL=8

# Prediction Reversal Check
PREDICTION_REVERSAL_ENABLED=true
PREDICTION_REVERSAL_CONFIDENCE=80

# Session Timing (ICT: focus on high-liquidity sessions)
ALLOWED_SESSIONS=london,ny_killzone

# Partial Take Profits
PARTIAL_TP_ENABLED=true
PARTIAL_TP_RATIOS=0.5,0.5
PARTIAL_TP_RR_LEVELS=1.0,2.0

# Trailing Stop
TRAILING_STOP_ENABLED=true
TRAIL_AFTER_RR=1.0
TRAIL_DISTANCE_PCT=0.5

# Price Updates
PRICE_UPDATE_INTERVAL_MS=30000

# CoinGecko Rate Limiting
COINGECKO_MIN_DELAY_MS=2000
